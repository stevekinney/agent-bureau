{
  "name": "armorer-conversationalist-integration",
  "private": true,
  "type": "module",
  "scripts": {
    "transit": "bun --cwd ../armorer run build && bun --cwd ../conversationalist run build",
    "test": "bun run scripts/run-tests.ts",
    "check-types": "tsc --noEmit",
    "validate": "bun run test && bun run check-types",
    "integration": "bun run validate"
  },
  "dependencies": {
    "armorer": "workspace:*",
    "conversationalist": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9"
  }
}

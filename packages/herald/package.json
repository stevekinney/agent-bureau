{
  "name": "herald",
  "version": "0.1.0",
  "description": "LLM provider factories that return GenerateFunction implementations for Anthropic, OpenAI, and Gemini. Each factory wires conversation and tool adapters to an SDK call.",
  "keywords": [
    "ai",
    "llm",
    "provider",
    "anthropic",
    "openai",
    "gemini",
    "agent",
    "typescript"
  ],
  "homepage": "https://github.com/stevekinney/agent-bureau#readme",
  "bugs": {
    "url": "https://github.com/stevekinney/agent-bureau/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stevekinney/agent-bureau.git"
  },
  "license": "MIT",
  "author": "Steve Kinney <hello@stevekinney.net>",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "bun": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./anthropic": {
      "import": "./dist/anthropic.js",
      "bun": "./dist/anthropic.js",
      "require": "./dist/anthropic.cjs",
      "default": "./dist/anthropic.js",
      "types": "./dist/anthropic.d.ts"
    },
    "./openai": {
      "import": "./dist/openai.js",
      "bun": "./dist/openai.js",
      "require": "./dist/openai.cjs",
      "default": "./dist/openai.js",
      "types": "./dist/openai.d.ts"
    },
    "./gemini": {
      "import": "./dist/gemini.js",
      "bun": "./dist/gemini.js",
      "require": "./dist/gemini.cjs",
      "default": "./dist/gemini.js",
      "types": "./dist/gemini.d.ts"
    },
    "./instrumentation": {
      "import": "./dist/instrumentation/index.js",
      "bun": "./dist/instrumentation/index.js",
      "require": "./dist/instrumentation/index.cjs",
      "default": "./dist/instrumentation/index.js",
      "types": "./dist/instrumentation/index.d.ts"
    },
    "./test": {
      "import": "./dist/test/index.js",
      "bun": "./dist/test/index.js",
      "require": "./dist/test/index.cjs",
      "default": "./dist/test/index.js",
      "types": "./dist/test/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "bun run scripts/build.ts",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist coverage tsconfig.tsbuildinfo",
    "ci": "bun run validate && bun run build",
    "dev": "bun --watch run src/index.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepack": "bun run clean && bun run build",
    "prepublishOnly": "bun run clean && bun run build",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "coverage:check": "bun run scripts/check-coverage.ts",
    "validate": "bun run format:check && bun run lint && bun run check-types && bun run test"
  },
  "dependencies": {
    "armorer": "workspace:*",
    "conversationalist": "workspace:*",
    "interoperability": "workspace:*"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@opentelemetry/api": "^1.9.0",
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^10.0.1",
    "@google/generative-ai": "^0.24.1",
    "@types/bun": "^1.3.9",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-regexp": "^3.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.3.0",
    "openai": "^6.15.0",
    "operative": "workspace:*",
    "typescript-eslint": "^8.55.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.50.0",
    "@opentelemetry/api": "^1.9.0",
    "openai": ">=4.0.0",
    "@google/generative-ai": ">=0.20.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@opentelemetry/api": {
      "optional": true
    },
    "openai": {
      "optional": true
    },
    "@google/generative-ai": {
      "optional": true
    }
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}

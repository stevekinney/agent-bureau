{
  "name": "interoperability",
  "private": true,
  "version": "0.0.1",
  "description": "Shared tool interoperability types and materialization utilities",
  "license": "MIT",
  "author": "Steve Kinney <hello@stevekinney.net>",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./dist/index.js",
      "browser": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "bun run scripts/build.ts",
    "check-types": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "coverage:check": "bun run ../../scripts/check-coverage.ts",
    "validate": "bun run check-types && bun run lint && bun run test && bun run build"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9"
  },
  "engines": {
    "bun": ">=1.3.13"
  }
}

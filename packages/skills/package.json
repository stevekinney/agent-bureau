{
  "name": "skills",
  "private": true,
  "version": "0.0.1",
  "description": "Skills platform for agent-bureau: discover, load, and use AgentSkills-compatible SKILL.md content with a self-improvement engine.",
  "keywords": [
    "ai",
    "llm",
    "agent",
    "skills",
    "self-improvement",
    "typescript"
  ],
  "homepage": "https://github.com/stevekinney/agent-bureau#readme",
  "bugs": {
    "url": "https://github.com/stevekinney/agent-bureau/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stevekinney/agent-bureau.git"
  },
  "license": "MIT",
  "author": "Steve Kinney <hello@stevekinney.net>",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "bun": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./test": {
      "import": "./dist/test/index.js",
      "bun": "./dist/test/index.js",
      "require": "./dist/test/index.cjs",
      "default": "./dist/test/index.js",
      "types": "./dist/test/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "bun run scripts/build.ts",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist coverage tsconfig.tsbuildinfo node_modules/.cache/tsconfig.tsbuildinfo",
    "ci": "bun run validate && bun run build",
    "coverage:check": "bun run ../../scripts/check-coverage.ts",
    "dev": "bun --watch run src/index.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "validate": "bun run format:check && bun run lint && bun run check-types && bun run test"
  },
  "dependencies": {
    "@lostgradient/weft": "^0.9.0",
    "armorer": "workspace:*",
    "gray-matter": "^4.0.3",
    "interoperability": "workspace:*",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}

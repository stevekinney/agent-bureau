  "scripts": {
    "build": "bun run scripts/build.ts",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist coverage tsconfig.tsbuildinfo",
    "ci": "bun run validate && bun run build",
    "coverage:check": "bun run ../../scripts/check-coverage.ts",
    "dev": "bun --watch run src/index.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "validate": "bun run format:check && bun run lint && bun run check-types && bun run test"
  },

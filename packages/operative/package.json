{
  "name": "operative",
  "version": "0.1.0",
  "description": "A composable agent loop that wires Armorer and Conversationalist into the standard agentic cycle. Provide your own generate function — operative never imports an LLM SDK.",
  "keywords": [
    "ai",
    "llm",
    "agent",
    "agent-loop",
    "tool-calling",
    "orchestrator",
    "typescript"
  ],
  "homepage": "https://github.com/stevekinney/agent-bureau#readme",
  "bugs": {
    "url": "https://github.com/stevekinney/agent-bureau/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stevekinney/agent-bureau.git"
  },
  "license": "MIT",
  "author": "Steve Kinney <hello@stevekinney.net>",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "bun": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./conditions": {
      "import": "./dist/conditions/index.js",
      "bun": "./dist/conditions/index.js",
      "require": "./dist/conditions/index.cjs",
      "default": "./dist/conditions/index.js",
      "types": "./dist/conditions/index.d.ts"
    },
    "./test": {
      "import": "./dist/test/index.js",
      "bun": "./dist/test/index.js",
      "require": "./dist/test/index.cjs",
      "default": "./dist/test/index.js",
      "types": "./dist/test/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "bun run scripts/build.ts",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist coverage tsconfig.tsbuildinfo",
    "ci": "bun run lint && bun run check-types && bun run coverage:check && bun run build",
    "coverage:check": "bun run scripts/check-coverage.ts",
    "dev": "bun --watch run src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepack": "bun run clean && bun run build",
    "prepublishOnly": "bun run clean && bun run build",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "validate": "bun run lint && bun run check-types && bun run coverage:check"
  },
  "dependencies": {
    "armorer": "workspace:*",
    "conversationalist": "workspace:*",
    "interoperability": "workspace:*",
    "event-emission": "0.3.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "zod": "^4.3.6"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}

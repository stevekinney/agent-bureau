{
  "name": "evaluation",
  "version": "0.1.0",
  "private": true,
  "description": "Agent behavior evaluation framework: matchers, metrics, runner, and report comparison for testing whether agents do the right thing.",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "bun": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./prompt-injection-benchmark": {
      "import": "./dist/prompt-injection-benchmark.js",
      "bun": "./dist/prompt-injection-benchmark.js",
      "require": "./dist/prompt-injection-benchmark.cjs",
      "default": "./dist/prompt-injection-benchmark.js",
      "types": "./dist/prompt-injection-benchmark.d.ts"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "bun run scripts/build.ts",
    "check-types": "tsc --noEmit",
    "ci": "bun run validate && bun run build",
    "clean": "rm -rf dist coverage tsconfig.tsbuildinfo",
    "coverage:check": "bun run ../../scripts/check-coverage.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "validate": "bun run format:check && bun run lint && bun run check-types && bun run test"
  },
  "dependencies": {
    "operative": "workspace:*",
    "armorer": "workspace:*",
    "conversationalist": "workspace:*"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.9",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-regexp": "^3.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.3.0",
    "typescript-eslint": "^8.55.0",
    "zod": "^4.4.1"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}

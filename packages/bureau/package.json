{
  "name": "bureau",
  "private": true,
  "version": "0.0.1",
  "description": "The brain — a typed fleet of agents with shared configuration, durable orchestration, memory, and scheduling. Wraps operative, memory, armorer, and conversationalist into one self-contained, transport-agnostic unit.",
  "keywords": [
    "ai",
    "llm",
    "agent",
    "bureau",
    "fleet",
    "orchestration",
    "typescript"
  ],
  "homepage": "https://github.com/stevekinney/agent-bureau#readme",
  "bugs": {
    "url": "https://github.com/stevekinney/agent-bureau/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stevekinney/agent-bureau.git"
  },
  "license": "MIT",
  "author": "Steve Kinney <hello@stevekinney.net>",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./dist/index.js",
      "browser": "./dist/index.js",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./test": {
      "bun": "./dist/test/index.js",
      "browser": "./dist/test/index.js",
      "import": "./dist/test/index.js",
      "require": "./dist/test/index.cjs",
      "default": "./dist/test/index.js",
      "types": "./dist/test/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "bun run scripts/build.ts",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist coverage tsconfig.tsbuildinfo",
    "ci": "bun run validate && bun run build",
    "dev": "bun --watch run src/index.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "validate": "bun run format:check && bun run lint && bun run check-types && bun run test"
  },
  "dependencies": {
    "armorer": "workspace:*",
    "conversationalist": "workspace:*",
    "interoperability": "workspace:*",
    "lifecycle": "workspace:*",
    "memory": "workspace:*",
    "operative": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "zod": "^4.3.6"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}

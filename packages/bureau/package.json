{
  "name": "bureau",
  "version": "0.0.5",
  "private": true,
  "description": "The agent fleet brain: createBureau, runtime composition, durability, recovery, and agent assembly",
  "keywords": [
    "ai",
    "llm",
    "agent",
    "bureau",
    "fleet",
    "orchestration",
    "typescript"
  ],
  "homepage": "https://github.com/stevekinney/agent-bureau#readme",
  "bugs": {
    "url": "https://github.com/stevekinney/agent-bureau/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stevekinney/agent-bureau.git"
  },
  "license": "MIT",
  "author": "Steve Kinney <hello@stevekinney.net>",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./dist/index.js",
      "browser": "./dist/index.js",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./builder": {
      "bun": "./dist/builder/index.js",
      "browser": "./dist/builder/index.js",
      "import": "./dist/builder/index.js",
      "require": "./dist/builder/index.cjs",
      "default": "./dist/builder/index.js",
      "types": "./dist/builder/index.d.ts"
    },
    "./test": {
      "bun": "./dist/test/index.js",
      "browser": "./dist/test/index.js",
      "import": "./dist/test/index.js",
      "require": "./dist/test/index.cjs",
      "default": "./dist/test/index.js",
      "types": "./dist/test/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "bun run scripts/build.ts",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist coverage tsconfig.tsbuildinfo",
    "ci": "bun run validate && bun run build",
    "coverage:check": "bun run ../../scripts/check-coverage.ts",
    "dev": "bun --watch run src/index.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "validate": "bun run format:check && bun run lint && bun run check-types && bun run test"
  },
  "dependencies": {
    "@lostgradient/weft": "^0.15.0",
    "armorer": "workspace:*",
    "conversationalist": "workspace:*",
    "interoperability": "workspace:*",
    "lifecycle": "workspace:*",
    "memory": "workspace:*",
    "@lostgradient/operative": "workspace:*",
    "skills": "workspace:*",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@eslint/js": "^10.0.1",
    "@google/generative-ai": "^0.24.1",
    "@opentelemetry/api": "^1.9.0",
    "@types/bun": "^1.3.9",
    "eslint": "^10.0.0",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.55.0"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.50.0",
    "@google/generative-ai": ">=0.20.0",
    "@opentelemetry/api": "^1.9.0",
    "openai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@google/generative-ai": {
      "optional": true
    },
    "@opentelemetry/api": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  },
  "engines": {
    "bun": ">=1.3.13"
  }
}

{
  "name": "cloudflare",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Workers storage adapters for agent-bureau: Vectorize-backed memory record storage and Durable Object helpers.",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "bun": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./test": {
      "bun": "./src/test/index.ts",
      "default": "./src/test/index.ts"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "bun run scripts/build.ts",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist coverage tsconfig.tsbuildinfo",
    "ci": "bun run validate && bun run build",
    "coverage:check": "bun run ../../scripts/check-coverage.ts",
    "dev": "bun --watch run src/index.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "validate": "bun run format:check && bun run lint && bun run check-types && bun run test"
  },
  "dependencies": {
    "@lostgradient/weft": "^0.15.0",
    "interoperability": "workspace:*",
    "memory": "workspace:*",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260606.1",
    "@types/bun": "^1.3.9",
    "conversationalist": "workspace:*",
    "@lostgradient/operative": "workspace:*",
    "skills": "workspace:*"
  },
  "engines": {
    "bun": ">=1.3.13"
  }
}

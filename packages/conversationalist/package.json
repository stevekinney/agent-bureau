{
  "name": "conversationalist",
  "version": "0.0.12",
  "description": "A TypeScript library for managing AI conversation state",
  "keywords": [
    "conversation",
    "ai",
    "chat",
    "llm",
    "typescript"
  ],
  "homepage": "https://github.com/stevekinney/conversationalist#readme",
  "bugs": {
    "url": "https://github.com/stevekinney/conversationalist/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stevekinney/conversationalist.git"
  },
  "license": "MIT",
  "author": "Steve Kinney <hello@stevekinney.net>",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "bun": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./conversation": {
      "import": "./dist/conversation/index.js",
      "bun": "./dist/conversation/index.js",
      "default": "./dist/conversation/index.js",
      "types": "./dist/conversation/index.d.ts"
    },
    "./context": {
      "import": "./dist/context.js",
      "bun": "./dist/context.js",
      "default": "./dist/context.js",
      "types": "./dist/context.d.ts"
    },
    "./streaming": {
      "import": "./dist/streaming.js",
      "bun": "./dist/streaming.js",
      "default": "./dist/streaming.js",
      "types": "./dist/streaming.d.ts"
    },
    "./history": {
      "import": "./dist/history.js",
      "bun": "./dist/history.js",
      "default": "./dist/history.js",
      "types": "./dist/history.d.ts"
    },
    "./message": {
      "import": "./dist/message.js",
      "bun": "./dist/message.js",
      "default": "./dist/message.js",
      "types": "./dist/message.d.ts"
    },
    "./utilities": {
      "import": "./dist/utilities.js",
      "bun": "./dist/utilities.js",
      "default": "./dist/utilities.js",
      "types": "./dist/utilities.d.ts"
    },
    "./test": {
      "import": "./dist/test/index.js",
      "bun": "./dist/test/index.js",
      "default": "./dist/test/index.js",
      "types": "./dist/test/index.d.ts"
    },
    "./markdown": {
      "import": "./dist/markdown/index.js",
      "bun": "./dist/markdown/index.js",
      "default": "./dist/markdown/index.js",
      "types": "./dist/markdown/index.d.ts"
    },
    "./export": {
      "import": "./dist/export/index.js",
      "bun": "./dist/export/index.js",
      "default": "./dist/export/index.js",
      "types": "./dist/export/index.d.ts"
    },
    "./schemas": {
      "import": "./dist/schemas/index.js",
      "bun": "./dist/schemas/index.js",
      "default": "./dist/schemas/index.js",
      "types": "./dist/schemas/index.d.ts"
    },
    "./adapters/openai": {
      "import": "./dist/adapters/openai/index.js",
      "bun": "./dist/adapters/openai/index.js",
      "default": "./dist/adapters/openai/index.js",
      "types": "./dist/adapters/openai/index.d.ts"
    },
    "./adapters/anthropic": {
      "import": "./dist/adapters/anthropic/index.js",
      "bun": "./dist/adapters/anthropic/index.js",
      "default": "./dist/adapters/anthropic/index.js",
      "types": "./dist/adapters/anthropic/index.d.ts"
    },
    "./adapters/gemini": {
      "import": "./dist/adapters/gemini/index.js",
      "bun": "./dist/adapters/gemini/index.js",
      "default": "./dist/adapters/gemini/index.js",
      "types": "./dist/adapters/gemini/index.d.ts"
    },
    "./redaction": {
      "import": "./dist/redaction/index.js",
      "bun": "./dist/redaction/index.js",
      "default": "./dist/redaction/index.js",
      "types": "./dist/redaction/index.d.ts"
    },
    "./versioning": {
      "import": "./dist/versioning/index.js",
      "bun": "./dist/versioning/index.js",
      "default": "./dist/versioning/index.js",
      "types": "./dist/versioning/index.d.ts"
    },
    "./sort": {
      "import": "./dist/sort/index.js",
      "bun": "./dist/sort/index.js",
      "default": "./dist/sort/index.js",
      "types": "./dist/sort/index.d.ts"
    },
    "./persistence": {
      "import": "./dist/persistence/index.js",
      "bun": "./dist/persistence/index.js",
      "default": "./dist/persistence/index.js",
      "types": "./dist/persistence/index.d.ts"
    },
    "./composition": {
      "import": "./dist/composition/index.js",
      "bun": "./dist/composition/index.js",
      "default": "./dist/composition/index.js",
      "types": "./dist/composition/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "bun run scripts/build.ts",
    "check-types": "tsc --noEmit",
    "ci": "bun run validate && bun run build",
    "coverage:check": "bun run scripts/check-coverage.ts",
    "dev": "bun --watch run src/index.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "bun run ci",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "validate": "bun run format:check && bun run lint && bun run check-types && bun run test"
  },
  "dependencies": {
    "change-case": "^5.4.4",
    "event-emission": "0.3.0",
    "gray-matter": "^4.0.3",
    "interoperability": "workspace:*"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@eslint/markdown": "^7.5.1",
    "@google/generative-ai": "^0.24.1",
    "@types/bun": "^1.3.5",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "armorer": "workspace:*",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-regexp": "^2.10.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unicorn": "^62.0.0",
    "eslint-plugin-unused-imports": "^4.3.0",
    "globals": "^16.5.0",
    "openai": "^6.15.0",
    "typescript-eslint": "^8.50.0",
    "zod": "^4.2.1"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}

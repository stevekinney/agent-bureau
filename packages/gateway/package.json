{
  "name": "gateway",
  "version": "0.0.1",
  "private": true,
  "description": "HTTP gateway and web UI for agent-bureau",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "build": "bun run scripts/build.ts",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist coverage tsconfig.tsbuildinfo",
    "dev": "bun --watch run src/start.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "bun run src/start.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "validate": "bun run format:check && bun run lint && bun run check-types && bun run test"
  },
  "dependencies": {
    "@lostgradient/cinder": "^0.9.0",
    "@lostgradient/weft": "^0.9.0",
    "armorer": "workspace:*",
    "bureau": "workspace:*",
    "conversationalist": "workspace:*",
    "hono": "^4.7.10",
    "interoperability": "workspace:*",
    "lifecycle": "workspace:*",
    "lucide-svelte": "^0.503.0",
    "memory": "workspace:*",
    "operative": "workspace:*",
    "skills": "workspace:*",
    "svelte": "^5.56.2",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.9",
    "bun-plugin-svelte": "0.0.6",
    "eslint": "^10.0.0",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.55.0"
  },
  "peerDependencies": {
    "@hono/node-server": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@hono/node-server": {
      "optional": true
    }
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}

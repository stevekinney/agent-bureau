{
  "name": "gateway",
  "version": "0.0.1",
  "private": true,
  "description": "HTTP gateway and web UI for agent-bureau",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "build": "bun run scripts/build.ts",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist coverage tsconfig.tsbuildinfo",
    "dev": "bun --watch run src/index.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "validate": "bun run format:check && bun run lint && bun run check-types && bun run test"
  },
  "dependencies": {
    "@lostgradient/cinder": "^0.6.0",
    "@lostgradient/weft": "^0.9.0",
    "@milkdown/ctx": "^7.17.3",
    "@milkdown/kit": "^7.17.3",
    "@milkdown/prose": "^7.17.3",
    "@shikijs/engine-oniguruma": "^3.21.0",
    "@shikijs/langs": "^3.21.0",
    "@shikijs/rehype": "^3.21.0",
    "@shikijs/types": "^3.21.0",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/unist": "^3.0.0",
    "armorer": "workspace:*",
    "bureau": "workspace:*",
    "comlink": "^4.4.2",
    "conversationalist": "workspace:*",
    "hast-util-sanitize": "^5.0.0",
    "hono": "^4.7.10",
    "interoperability": "workspace:*",
    "js-yaml": "^4.1.0",
    "lifecycle": "workspace:*",
    "lucide-svelte": "^0.503.0",
    "memory": "workspace:*",
    "operative": "workspace:*",
    "prosemirror-inputrules": "^1.5.1",
    "prosemirror-model": "^1.25.4",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.3",
    "rehype-katex": "^7.0.1",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-stringify": "^11.0.0",
    "shiki": "^3.21.0",
    "skills": "workspace:*",
    "svelte": "^5.56.2",
    "unified": "^11.0.5",
    "unist-util-remove": "^4.0.0",
    "unist-util-visit": "^5.0.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.9",
    "bun-plugin-svelte": "0.0.6",
    "eslint": "^10.0.0",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.55.0"
  },
  "peerDependencies": {
    "@hono/node-server": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@hono/node-server": {
      "optional": true
    }
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}

{
  "name": "agent-bureau",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "coverage:check": "turbo run coverage:check --filter=armorer --filter=conversationalist --filter=evaluation --filter=herald --filter=interoperability --filter=lifecycle --filter=memory --filter=operative --filter=sentinel --filter=skills",
    "dev": "turbo run dev",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "turbo run format:check",
    "integration": "turbo run integration --filter=integration",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "prepare": "lefthook install",
    "validate": "turbo run format:check lint check-types test",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun run scripts/release.ts",
    "check-package-shape": "bun run scripts/check-package-shape.ts armorer conversationalist"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-regexp": "^3.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.3.0",
    "lefthook": "^2.1.4",
    "prettier": "^3.7.4",
    "tsdown": "^0.22.1",
    "turbo": "^2.8.17",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.55.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.2",
  "workspaces": [
    "packages/*"
  ]
}

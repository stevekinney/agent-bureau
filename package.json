{
  "name": "agent-bureau",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev": "turbo run dev",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "turbo run format:check",
    "integration": "turbo run integration --filter=integration",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "prepare": "lefthook install",
    "validate": "turbo run format:check lint check-types test"
  },
  "devDependencies": {
    "lefthook": "^2.1.4",
    "prettier": "^3.7.4",
    "turbo": "^2.8.17",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.2",
  "workspaces": ["packages/*"]
}
